# FDA SafetyNet - environment configuration template.
# Copy to .env and fill in. Never commit .env.

# ---------- openFDA ----------
# Optional: raises rate limit (240/min -> 120k/day). Works without it for demo volumes.
OPENFDA_API_KEY=

# ---------- ClickHouse (local default; swap for ClickHouse Cloud) ----------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=safetynet
CLICKHOUSE_SECURE=false

# ---------- Synthetic data scale knobs ----------
SCALE_PHARMACIES=5000
SCALE_CUSTOMERS=1000000
NDC_OVERLAP_RATE=0.18

# ---------- OpenAI (OpenUI runtime cards + optional Phase 6 agents) ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- Orchestration ----------
USE_AGENTS=false

# ---------- Optional sponsor integrations (Phase 7) ----------
COMPOSIO_API_KEY=
SENSO_API_KEY=
TRUEFOUNDRY_API_KEY=
