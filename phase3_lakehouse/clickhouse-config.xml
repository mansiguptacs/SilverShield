<?xml version="1.0"?>
<!-- Minimal local ClickHouse server config for FDA SafetyNet.
     Data lives under ./clickhouse-data (gitignored). Listens on localhost. -->
<clickhouse>
    <logger>
        <level>warning</level>
        <console>1</console>
    </logger>

    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <listen_host>127.0.0.1</listen_host>

    <path>./clickhouse-data/</path>
    <tmp_path>./clickhouse-data/tmp/</tmp_path>
    <user_files_path>./clickhouse-data/user_files/</user_files_path>
    <format_schema_path>./clickhouse-data/format_schemas/</format_schema_path>

    <mark_cache_size>5368709120</mark_cache_size>
    <mlock_executable>false</mlock_executable>

    <profiles>
        <default>
            <max_memory_usage>10000000000</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
        </default>
    </profiles>

    <users>
        <default>
            <password></password>
            <networks>
                <ip>127.0.0.1</ip>
                <ip>::1</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>

    <quotas>
        <default></default>
    </quotas>
</clickhouse>
